<idea-plugin>
    <id>com.sercapnp</id>
    <name>SerCapnp</name>
    <version>3.0</version>
    <vendor email="xmonader@gmail.com" url="https://github.com/xmonader">xmonader</vendor>

    <description><![CDATA[
<h2>Cap'n Proto Language Support</h2>
<p>Full-featured Cap'n Proto (.capnp) schema language support for IntelliJ-based IDEs.</p>
<h3>Features</h3>
<ul>
  <li><b>Syntax highlighting</b> — keywords, types, identifiers, strings, numbers, constants, comments, unique IDs, ordinals</li>
  <li><b>Bracket matching</b> — auto-matching for <code>{}</code>, <code>[]</code>, <code>()</code></li>
  <li><b>Comment toggling</b> — use Ctrl+/ to toggle <code>#</code> line comments</li>
  <li><b>Code folding</b> — collapse struct, enum, and interface blocks</li>
  <li><b>Cap'n Proto ID generation</b> — generate unique 64-bit schema IDs (Ctrl+Alt+A, G)</li>
  <li><b>New file action</b> — File → New → Capnp File</li>
  <li><b>Color settings</b> — fully customizable syntax colors via Settings → Editor → Color Scheme → Cap'n Proto</li>
</ul>
]]></description>

    <change-notes><![CDATA[
    <ul>
      <li><b>3.0</b>: Major update — string, number, constant highlighting; comment toggling; brace matching; code folding; AnyPointer type; fixed lexer</li>
      <li><b>2.0</b>: Updated for IntelliJ Platform 2025.1</li>
      <li><b>1.0</b>: Initial release with syntax highlighting and ID generation</li>
    </ul>
    ]]></change-notes>

    <idea-version since-build="221"/>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Capnp file"
                  implementationClass="com.sercapnp.lang.CapnpFileType"
                  fieldName="INSTANCE"
                  language="Capnp"
                  extensions="capnp"/>
        <lang.parserDefinition
                language="Capnp"
                implementationClass="com.sercapnp.lang.CapnpParserDefinition"/>
        <lang.syntaxHighlighterFactory
                language="Capnp"
                implementationClass="com.sercapnp.lang.CapnpSyntaxHighlighterFactory"/>
        <lang.commenter
                language="Capnp"
                implementationClass="com.sercapnp.lang.CapnpCommenter"/>
        <lang.braceMatcher
                language="Capnp"
                implementationClass="com.sercapnp.lang.CapnpBraceMatcher"/>
        <lang.foldingBuilder
                language="Capnp"
                implementationClass="com.sercapnp.lang.CapnpFoldingBuilder"/>
        <colorSettingsPage implementation="com.sercapnp.lang.CapnpColorSettingsPage"/>
    </extensions>

    <actions>
        <action id="GenerateCapnpID" class="com.sercapnp.actions.GenerateCapnpID" text="GenerateCapnpID"
                description="Generate capnp id">
            <keyboard-shortcut first-keystroke="control alt A" second-keystroke="G" keymap="$default"/>
            <add-to-group group-id="ToolsMenu" anchor="first" />
        </action>
        <action id="Capnp.New" class="com.sercapnp.actions.NewFileAction" text="Capnp File" description="Create new Capnp file">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
    </actions>

</idea-plugin>
